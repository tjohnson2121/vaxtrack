# Optional: when set, all /api/* routes require:
#   Authorization: Bearer <same value>
# The Vaccine sources UI can store this in session storage via "Admin API access".
ADMIN_TOKEN=

# Anthropic: rule extraction from fetched source snapshots (admin / Sources UI).
ANTHROPIC_API_KEY=
# Optional override, e.g. claude-3-5-sonnet-20241022
ANTHROPIC_RULES_MODEL=

# Source scraper — GitHub issue notifications.
# Without these, `npm run scrape` still detects changes and writes new
# snapshots locally, but won't open GitHub issues.
# Create a fine-grained PAT with Issues: read+write on this repo:
#   https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=
GITHUB_REPO=tjohnson2121/vaxtrack
